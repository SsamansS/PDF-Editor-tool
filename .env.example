# Скопируйте в .env и задайте значения, чтобы включить авторизацию (HTTP Basic Auth).
# Если переменные не заданы — авторизация ВЫКЛЮЧЕНА (режим локальной разработки).
# Файл .env в гит не коммитится (см. .gitignore).

PDF_EDITOR_USER=admin
PDF_EDITOR_PASSWORD=change-me

# Адрес и порт сервера. По умолчанию 127.0.0.1:8765 (только локально).
# За nginx-прокси оставляйте 127.0.0.1 — наружу не выставляйте.
PDF_EDITOR_HOST=127.0.0.1
PDF_EDITOR_PORT=8765
